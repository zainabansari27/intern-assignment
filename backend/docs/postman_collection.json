{
  "info": {
    "name": "Intern Assignment API",
    "description": "Auth + RBAC + Task CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"supersecure123\",\n  \"role\": \"user\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"supersecure123\"\n}"
        }
      }
    },
    {
      "name": "Tasks - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/tasks",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Finish assignment\",\n  \"description\": \"Implement complete backend\",\n  \"status\": \"todo\"\n}"
        }
      }
    },
    {
      "name": "Tasks - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/tasks"
      }
    },
    {
      "name": "Tasks - Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/tasks/{{taskId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"done\"\n}"
        }
      }
    },
    {
      "name": "Tasks - Delete",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/tasks/{{taskId}}"
      }
    },
    {
      "name": "Users - Admin Only",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/users"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "taskId", "value": "1" }
  ]
}